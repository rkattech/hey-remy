---
import Layout from '../layouts/Layout.astro';

const waitlistMailto =
  'mailto:support@hootventures.ai?subject=Remy%20waitlist&body=Hi%2C%20I%27d%20like%20early%20access%20to%20Remy.%0A%0AName%3A%20%0ADevice%20(iPhone%20%2F%20Android)%3A%20';

const steps = [
  {
    n: '01',
    title: 'Sign in with Google',
    body: 'No new account. No password. Sign in with the Gmail you already use.',
  },
  {
    n: '02',
    title: 'Tell Remy what you need',
    body: '"Book my dentist for sometime in May, prefer Thursday or Friday." In plain English. Like a real assistant.',
  },
  {
    n: '03',
    title: 'Remy asks before anything permanent',
    body: 'Remy drafts the email, finds the slot, shows you the plan. Nothing gets sent or booked until you tap Approve.',
  },
];

const capabilities = [
  {
    title: 'Book appointments',
    body: 'Dentist, doctor, stylist, mechanic. Remy finds the time, drafts the email, handles the back and forth.',
    icon: 'M8 7V3m8 4V3M3.5 11h17M5 7h14a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V9a2 2 0 0 1 2-2z',
  },
  {
    title: 'Manage your calendar',
    body: "See what's on your plate, find a time that works, protect the blocks you care about.",
    icon: 'M12 8v4l3 2m6-2a9 9 0 1 1-18 0 9 9 0 0 1 18 0z',
  },
  {
    title: 'Triage your inbox',
    body: "See what needs you. Draft replies. Ignore what doesn't matter. Find that email from three months ago.",
    icon: 'M3 8l9 6 9-6M5 19h14a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2z',
  },
  {
    title: 'Remember what matters',
    body: "The people, the decisions, the things you care about. Remy gets smarter the more you use it.",
    icon: 'M13 10V3L4 14h7v7l9-11h-7z',
  },
];

const whys = [
  {
    title: 'Private by design',
    body: 'Your email and calendar tokens are encrypted at rest. Row-level database isolation means only you can see your own data. Full stop.',
  },
  {
    title: 'Safe by default',
    body: 'Remy never sends an email, makes a call, or books a meeting without your explicit approval. Every irreversible action waits for your tap.',
  },
  {
    title: 'Gets smarter with use',
    body: 'Every conversation teaches Remy the people and preferences that matter to you. Day 30 is noticeably better than day 1.',
  },
];

const faq = [
  {
    q: 'Is my data private?',
    a: "Yes. OAuth tokens are encrypted with AES-GCM before they touch the database. Every table uses row-level security so only you can see your own data. We don't read your email. We don't sell anything.",
  },
  {
    q: 'Do I need to install anything weird?',
    a: 'Just the app. No CLI, no browser extension, no daemon running on your laptop. iOS and Android.',
  },
  {
    q: 'What does it cost?',
    a: "Free during early access. We'll share pricing well before you'd be asked to pay.",
  },
  {
    q: 'When can I try it?',
    a: "We're onboarding in small batches to keep the experience tight. Join the waitlist and we'll reach out as we open the next cohort.",
  },
  {
    q: 'How is this different from ChatGPT or Siri?',
    a: 'ChatGPT can tell you about your dentist. Remy books the appointment. Siri reads one email. Remy triages your whole inbox. An assistant that does real work, not a chatbot that talks about it.',
  },
  {
    q: "Who's behind this?",
    a: 'Built by Rohit Kapoor at Hoot Ventures. Questions: support@hootventures.ai.',
  },
];
---

<Layout>
  <header class="mx-auto max-w-6xl px-6 pt-6 sm:pt-8">
    <nav class="flex items-center justify-between">
      <a href="/" class="flex items-center gap-2.5 group">
        <span
          class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-[var(--ink)] text-[var(--bg)] text-sm font-semibold"
          aria-hidden="true">R</span>
        <span class="italic-serif text-xl tracking-tight">Remy</span>
      </a>
      <a
        href={waitlistMailto}
        class="inline-flex items-center rounded-full bg-[var(--ink)] px-4 py-2 text-sm font-medium text-[var(--bg-raised)] transition hover:opacity-85">
        Join the waitlist
      </a>
    </nav>
  </header>

  <section class="mx-auto max-w-6xl px-6 pt-14 pb-16 sm:pt-20 sm:pb-24">
    <div class="grid gap-12 lg:grid-cols-[1.1fr_0.9fr] lg:gap-16 lg:items-center">
      <div>
        <div class="inline-flex items-center gap-2 rounded-full bg-[var(--accent-soft)]/60 border border-[var(--accent-soft)] px-3 py-1 text-xs font-medium text-[var(--accent-ink)] mb-8">
          <span class="h-1.5 w-1.5 rounded-full bg-[var(--accent)]"></span>
          Early access · iOS and Android
        </div>
        <h1 class="text-[clamp(2.75rem,6vw,4.75rem)] leading-[1.02] tracking-[-0.02em] font-medium">
          Your own
          <span class="italic-serif text-[1.1em]">AI agent</span>.
          <br />
          <span class="text-[var(--muted)]">Without the</span>
          <span class="italic-serif text-[var(--muted)] text-[1.1em]">setup</span><span class="text-[var(--muted)]">.</span>
        </h1>
        <p class="mt-7 max-w-xl text-lg sm:text-xl text-[var(--ink-soft)] leading-relaxed">
          Remy reads your email, checks your calendar, books appointments, and
          remembers what matters to you. Open the app, sign in with Google,
          start talking.
        </p>
        <div class="mt-9 flex flex-col gap-3 sm:flex-row sm:items-center">
          <a
            href={waitlistMailto}
            class="group inline-flex items-center justify-center rounded-full bg-[var(--ink)] px-6 py-3.5 text-base font-medium text-[var(--bg-raised)] shadow-[0_10px_30px_-10px_rgba(26,23,19,0.3)] transition-all hover:shadow-[0_14px_40px_-10px_rgba(26,23,19,0.4)] hover:-translate-y-0.5">
            Join the waitlist
            <svg class="ml-2 h-4 w-4 transition-transform group-hover:translate-x-0.5" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <path d="M4 10h12m-5-5 5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
          <a
            href="#how"
            class="inline-flex items-center justify-center rounded-full border border-[var(--line-strong)] bg-[var(--bg-raised)]/60 backdrop-blur px-6 py-3.5 text-base font-medium text-[var(--ink)] transition hover:bg-[var(--bg-raised)]">
            See how it works
          </a>
        </div>
        <div class="mt-8 flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-[var(--muted)]">
          <div class="flex items-center gap-2">
            <svg class="h-4 w-4 text-[var(--accent)]" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 1 1 1.06-1.06l3.895 3.895 7.477-9.814a.75.75 0 0 1 1.052-.148z" clip-rule="evenodd" />
            </svg>
            Encrypted at rest
          </div>
          <div class="flex items-center gap-2">
            <svg class="h-4 w-4 text-[var(--accent)]" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 1 1 1.06-1.06l3.895 3.895 7.477-9.814a.75.75 0 0 1 1.052-.148z" clip-rule="evenodd" />
            </svg>
            Approvals for everything
          </div>
        </div>
      </div>

      <!-- Phone mockup -->
      <div class="relative flex justify-center lg:justify-end">
        <div
          class="absolute inset-0 -z-10 blur-3xl opacity-60"
          style="background: radial-gradient(circle at center, rgba(254,215,170,0.8), transparent 65%);"
          aria-hidden="true">
        </div>
        <div class="relative mx-auto w-full max-w-[320px]">
          <div class="relative rounded-[52px] bg-[#0c0b0a] p-[10px] shadow-[0_40px_80px_-20px_rgba(26,23,19,0.45),0_0_0_1px_rgba(26,23,19,0.5)]">
            <div class="relative aspect-[9/19.5] overflow-hidden rounded-[42px] bg-[var(--bg)]">
              <div class="absolute top-3 left-1/2 -translate-x-1/2 z-20 h-7 w-[110px] rounded-full bg-black"></div>
              <div class="absolute top-0 left-0 right-0 z-10 flex items-center justify-between px-6 pt-4 pb-2 text-[11px] font-semibold text-[var(--ink)]">
                <span>9:41</span>
                <span class="flex items-center gap-1" aria-hidden="true">
                  <svg class="h-3 w-3" viewBox="0 0 16 12" fill="currentColor"><path d="M1 8.5v3h2v-3H1zm4-2v5h2v-5H5zm4-2v7h2v-7H9zm4-2v9h2v-9h-2z"/></svg>
                  <svg class="h-3 w-4" viewBox="0 0 20 12" fill="none" stroke="currentColor" stroke-width="1.2"><rect x="1" y="3" width="16" height="6" rx="1.5"/><rect x="3" y="5" width="12" height="2" fill="currentColor" stroke="none"/><path d="M18 5v2" stroke-linecap="round"/></svg>
                </span>
              </div>

              <div class="absolute inset-0 pt-12 flex flex-col">
                <div class="flex items-center gap-3 border-b border-[var(--line)] px-4 py-3">
                  <div class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-[var(--ink)] text-[var(--bg-raised)] text-sm font-semibold" aria-hidden="true">R</div>
                  <div class="leading-tight">
                    <div class="text-[13px] font-semibold">Remy</div>
                    <div class="text-[11px] text-[var(--muted)]">active now</div>
                  </div>
                </div>

                <div class="flex-1 overflow-hidden px-3.5 py-4 space-y-3 text-[13px]">
                  <div class="flex justify-end">
                    <div class="max-w-[82%] rounded-2xl rounded-br-md bg-[var(--ink)] text-[var(--bg-raised)] px-3.5 py-2 leading-snug">
                      Book my dentist for sometime in May, prefer Thu or Fri.
                    </div>
                  </div>

                  <div class="flex">
                    <div class="max-w-[86%] rounded-2xl rounded-bl-md bg-[var(--bg-card)] px-3.5 py-2.5 shadow-[0_2px_8px_-4px_rgba(26,23,19,0.1)] leading-snug">
                      <p class="text-[var(--ink)]">Found your dentist in Gmail: <strong>Smile Dental</strong>. Last cleaning Oct 14, so you're due.</p>
                      <p class="mt-2 text-[var(--ink)]">Three slots are open:</p>
                      <ul class="mt-1.5 space-y-0.5 text-[12px] text-[var(--ink-soft)]">
                        <li>· Thu <strong>May 14</strong>, 9:00 AM</li>
                        <li>· Fri <strong>May 22</strong>, 10:30 AM</li>
                        <li>· Thu <strong>May 28</strong>, 8:30 AM</li>
                      </ul>
                    </div>
                  </div>

                  <div class="flex justify-end">
                    <div class="max-w-[60%] rounded-2xl rounded-br-md bg-[var(--ink)] text-[var(--bg-raised)] px-3.5 py-2 leading-snug">
                      Thursday the 14th, please.
                    </div>
                  </div>

                  <div class="flex">
                    <div class="max-w-[92%] rounded-2xl rounded-bl-md bg-[var(--bg-card)] px-3.5 py-2.5 shadow-[0_2px_8px_-4px_rgba(26,23,19,0.1)] leading-snug">
                      <p class="text-[var(--ink)]">Drafted for your approval:</p>
                      <div class="mt-2 rounded-lg border border-[var(--line)] bg-stone-50/80 p-2.5 text-[11.5px] leading-snug text-[var(--ink-soft)]">
                        Hi, would love to come in Thursday May 14 at 9 AM for a cleaning. Anything I should bring?
                      </div>
                      <div class="mt-2.5 flex gap-2">
                        <button type="button" disabled class="rounded-full bg-[var(--accent)] text-white text-[11px] font-medium px-3 py-1.5 opacity-95">
                          Approve &amp; Send
                        </button>
                        <button type="button" disabled class="rounded-full border border-[var(--line-strong)] text-[11px] font-medium px-3 py-1.5 text-[var(--ink-soft)]">
                          Edit
                        </button>
                      </div>
                    </div>
                  </div>
                </div>

                <div class="border-t border-[var(--line)] bg-[var(--bg-raised)]/80 px-3 py-3 flex items-center gap-2">
                  <div class="flex-1 rounded-full border border-[var(--line)] bg-[var(--bg)] px-4 py-2 text-[12px] text-[var(--muted)]">
                    Message Remy…
                  </div>
                  <div class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-[var(--ink)] text-[var(--bg-raised)]" aria-hidden="true">
                    <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="none">
                      <path d="M10 15V5m0 0-4 4m4-4 4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <p class="mt-5 text-center text-xs text-[var(--muted)] italic-serif text-sm">
            A typical conversation with Remy
          </p>
        </div>
      </div>
    </div>
  </section>

  <section id="how" class="relative border-y border-[var(--line)] bg-[var(--bg-raised)]/70 backdrop-blur-sm fade-in">
    <div class="mx-auto max-w-6xl px-6 py-24 sm:py-28">
      <div class="max-w-3xl">
        <p class="text-[13px] font-medium uppercase tracking-[0.18em] text-[var(--accent)]">
          How it works
        </p>
        <h2 class="mt-4 text-4xl sm:text-5xl tracking-tight leading-[1.05]">
          Three steps. <span class="italic-serif text-[var(--muted)]">Nothing to configure.</span>
        </h2>
        <p class="mt-5 text-lg text-[var(--ink-soft)] max-w-2xl">
          Most AI tools ask you to be a developer. Remy doesn't. If you can
          text a friend, you can use it.
        </p>
      </div>

      <ol class="mt-16 grid gap-10 sm:grid-cols-3 relative">
        <div
          class="hidden sm:block absolute top-6 left-[16.67%] right-[16.67%] h-px bg-gradient-to-r from-transparent via-[var(--line-strong)] to-transparent"
          aria-hidden="true">
        </div>
        {
          steps.map((s) => (
            <li class="relative">
              <div class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-[var(--bg)] border border-[var(--line)] text-[var(--accent)] relative z-10">
                <span class="italic-serif text-xl">{s.n}</span>
              </div>
              <h3 class="mt-5 text-xl tracking-tight font-medium">{s.title}</h3>
              <p class="mt-3 text-[var(--ink-soft)] leading-relaxed">{s.body}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-6 py-24 sm:py-32 fade-in">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div class="max-w-2xl">
        <p class="text-[13px] font-medium uppercase tracking-[0.18em] text-[var(--accent)]">
          What Remy does
        </p>
        <h2 class="mt-4 text-4xl sm:text-5xl tracking-tight leading-[1.05]">
          An assistant that <span class="italic-serif">actually does things</span>.
        </h2>
      </div>
      <p class="text-lg text-[var(--ink-soft)] max-w-sm">
        Not a chatbot. A real helper that reads, writes, and follows through.
      </p>
    </div>

    <div class="mt-14 grid gap-px sm:grid-cols-2 rounded-3xl overflow-hidden border border-[var(--line)] bg-[var(--line)]">
      {
        capabilities.map((c, i) => (
          <div class="group relative p-8 sm:p-10 bg-[var(--bg-card)] transition-colors hover:bg-[var(--bg-raised)]">
            <div class="flex items-start gap-5">
              <div class="shrink-0 inline-flex h-11 w-11 items-center justify-center rounded-xl bg-[var(--accent-soft)]/50 border border-[var(--accent-soft)] text-[var(--accent-ink)]">
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d={c.icon} />
                </svg>
              </div>
              <div>
                <h3 class="text-xl tracking-tight font-medium">{c.title}</h3>
                <p class="mt-2 text-[var(--ink-soft)] leading-relaxed">{c.body}</p>
              </div>
            </div>
            <div class="absolute top-5 right-5 text-[var(--muted)] italic-serif text-sm opacity-60">{(i + 1).toString().padStart(2, '0')}</div>
          </div>
        ))
      }
    </div>
  </section>

  <section class="relative fade-in overflow-hidden">
    <div class="absolute inset-0 -z-10 bg-[var(--ink)]"></div>
    <div class="absolute inset-0 -z-10 opacity-30" style="background: radial-gradient(ellipse at 30% 0%, rgba(254,215,170,0.25), transparent 55%);" aria-hidden="true"></div>
    <div class="mx-auto max-w-6xl px-6 py-24 sm:py-32 text-[var(--bg-raised)]">
      <div class="max-w-3xl">
        <p class="text-[13px] font-medium uppercase tracking-[0.18em] text-[var(--accent-soft)]">
          Why Remy
        </p>
        <h2 class="mt-4 text-4xl sm:text-6xl tracking-[-0.02em] leading-[1.02] text-[var(--bg-raised)]">
          Powerful. <span class="italic-serif text-[var(--accent-soft)]">Private.</span>
          <br />
          <span class="italic-serif">Patient.</span>
        </h2>
      </div>

      <div class="mt-16 grid gap-12 sm:grid-cols-3">
        {
          whys.map((w, i) => (
            <div>
              <div class="italic-serif text-[var(--accent-soft)] text-3xl mb-5">0{i + 1}</div>
              <h3 class="text-xl tracking-tight font-medium text-[var(--bg-raised)]">{w.title}</h3>
              <p class="mt-3 text-[rgba(255,251,245,0.72)] leading-relaxed">{w.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-6 py-24 sm:py-32 fade-in">
    <div class="grid gap-10 lg:grid-cols-[1fr_1.5fr] lg:gap-20">
      <div>
        <p class="text-[13px] font-medium uppercase tracking-[0.18em] text-[var(--accent)]">
          Questions
        </p>
        <h2 class="mt-4 text-4xl sm:text-5xl tracking-tight leading-[1.02]">
          The answers <span class="italic-serif">up front</span>.
        </h2>
        <p class="mt-6 text-[var(--ink-soft)] max-w-sm leading-relaxed">
          Not finding what you're looking for?
          <a class="text-[var(--accent)] underline underline-offset-4 decoration-1 hover:decoration-2"
             href="mailto:support@hootventures.ai">Email us</a>.
        </p>
      </div>
      <div class="border-t border-[var(--line-strong)]">
        {
          faq.map((item) => (
            <details class="group border-b border-[var(--line-strong)] py-6">
              <summary class="flex cursor-pointer list-none items-start justify-between gap-6">
                <h3 class="text-xl tracking-tight font-medium">{item.q}</h3>
                <span
                  class="mt-1 shrink-0 inline-flex h-6 w-6 items-center justify-center rounded-full border border-[var(--line-strong)] text-[var(--muted)] transition-transform group-open:rotate-45"
                  aria-hidden="true">
                  <svg class="h-3 w-3" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.6">
                    <path d="M6 2v8M2 6h8" stroke-linecap="round" />
                  </svg>
                </span>
              </summary>
              <p class="mt-4 text-[var(--ink-soft)] leading-relaxed">{item.a}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-6 pb-24 sm:pb-32">
    <div class="relative overflow-hidden rounded-[32px] bg-gradient-to-br from-[#1a1713] via-[#2a1e17] to-[#3d2416] px-8 py-20 sm:px-16 sm:py-28 text-center text-[var(--bg-raised)]">
      <div class="absolute top-0 right-0 w-1/2 h-full -z-0 opacity-40" style="background: radial-gradient(ellipse at top right, rgba(254,215,170,0.35), transparent 60%);" aria-hidden="true"></div>
      <div class="relative">
        <h2 class="text-4xl sm:text-6xl tracking-[-0.02em] leading-[1.02] max-w-3xl mx-auto">
          Get <span class="italic-serif text-[var(--accent-soft)]">your own</span>
          AI assistant.
        </h2>
        <p class="mx-auto mt-6 max-w-xl text-lg text-[rgba(255,251,245,0.82)] leading-relaxed">
          We're rolling out in small batches so the product stays sharp.
          Drop us your email and we'll reach out as the next cohort opens.
        </p>
        <div class="mt-10">
          <a
            href={waitlistMailto}
            class="group inline-flex items-center justify-center rounded-full bg-[var(--bg-raised)] px-8 py-4 text-base font-medium text-[var(--ink)] shadow-[0_20px_50px_-10px_rgba(0,0,0,0.5)] transition-all hover:-translate-y-0.5 hover:shadow-[0_25px_60px_-10px_rgba(0,0,0,0.6)]">
            Join the waitlist
            <svg class="ml-2 h-4 w-4 transition-transform group-hover:translate-x-0.5" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <path d="M4 10h12m-5-5 5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <footer class="border-t border-[var(--line)] bg-[var(--bg-raised)]/40">
    <div class="mx-auto flex max-w-6xl flex-col items-start gap-4 px-6 py-10 sm:flex-row sm:items-center sm:justify-between">
      <div class="flex items-center gap-2">
        <span
          class="inline-flex h-7 w-7 items-center justify-center rounded-full bg-[var(--ink)] text-[var(--bg-raised)] text-xs font-semibold"
          aria-hidden="true">R</span>
        <span class="italic-serif text-base">Remy</span>
        <span class="text-sm text-[var(--muted)]">· by Hoot Ventures</span>
      </div>
      <div class="flex items-center gap-6 text-sm text-[var(--ink-soft)]">
        <a class="hover:text-[var(--ink)]" href="mailto:support@hootventures.ai">
          support@hootventures.ai
        </a>
        <a class="hover:text-[var(--ink)]" href="/privacy">Privacy</a>
      </div>
    </div>
    <div class="mx-auto max-w-6xl px-6 pb-10 text-xs text-[var(--muted)]">
      Remy is in active development. Features and scope may change as we learn.
    </div>
  </footer>
</Layout>
